{
  "name": "am4-tone-agent",
  "version": "0.1.0",
  "description": "Talk to Claude, get AM4 tones. Local MCP server for Fractal AM4.",
  "private": true,
  "license": "Apache-2.0",
  "author": "Stephen Staker <stephenstaker@gmail.com>",
  "type": "module",
  "scripts": {
    "probe": "tsx scripts/probe.ts",
    "sniff": "tsx scripts/sniff.ts",
    "diff-syx": "tsx scripts/diff-syx.ts",
    "scrape-wiki": "tsx scripts/scrape-wiki.ts",
    "extract-lineage": "tsx scripts/extract-lineage.ts",
    "verify-pack": "tsx scripts/verify-pack.ts",
    "verify-msg": "tsx scripts/verify-msg.ts",
    "verify-transpile": "tsx scripts/verify-transpile.ts",
    "verify-enum-lookup": "tsx scripts/verify-enum-lookup.ts",
    "verify-echo": "tsx scripts/verify-echo.ts",
    "verify-cache-params": "tsx scripts/verify-cache-params.ts",
    "gen-params": "tsx scripts/gen-params-from-cache.ts",
    "smoke-server": "tsx scripts/smoke-server.ts",
    "write-test": "tsx scripts/write-test.ts",
    "server": "tsx src/server/index.ts",
    "build": "tsc",
    "test": "npm run verify-pack && npm run verify-msg && npm run verify-transpile && npm run verify-enum-lookup && npm run verify-echo && npm run verify-cache-params && npm run smoke-server",
    "test:jest": "jest --testPathIgnorePatterns=integration",
    "test:jest:all": "jest",
    "preflight": "tsc --noEmit && npm test"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "midi": "^2.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.0.0",
    "jest": "^29.0.0",
    "@types/jest": "^29.0.0",
    "ts-jest": "^29.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
